#!/system/bin/sh

# ==============================================================================
# [ Flux TProxy & Routing Manager ]
# Description: Atomic iptables-restore application and PBR routing management.
# ==============================================================================

set -eu
[ -n "${BASH_VERSION:-}" ] && set -o pipefail

readonly SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"

. "${SCRIPT_DIR}/lib"
. "${SCRIPT_DIR}/log"

readonly LOG_COMPONENT="Tprx"

# ==============================================================================
# [ Core Operations ]
# ==============================================================================

# Manage iptables rules (apply/cleanup)
_rules() {
    local action="${1}"
    local family="${2}"
    local cmd="iptables-restore"
    [ "${family}" = "6" ] && cmd="ip6tables-restore"

    local file
    if [ "${family}" = "6" ]; then
        file="${CACHE_RULES_V6_FILE}"
    else
        file="${CACHE_RULES_V4_FILE}"
    fi

    if [ "${action}" = "cleanup" ]; then
        if [ "${family}" = "6" ]; then
            file="${CACHE_CLEANUP_V6_FILE}"
        else
            file="${CACHE_CLEANUP_V4_FILE}"
        fi
    fi

    [ -s "${file}" ] || {
        log_error "Rule cache missing: ${file}"
        return 1
    }

    local err
    if ! err=$(command "${cmd}" -w "${IPTABLES_WAIT}" --noflush <"${file}" 2>&1); then
        log_error "${cmd} failed"
        printf '%s\n' "${err}" | while IFS= read -r l; do
            log_error "  >> ${l}"
        done
        return 1
    fi
    return 0
}

# Manage policy routing (apply/cleanup)
_route() {
    local action="${1}"
    local family="${2}"
    local mark="${IPV4_MARK}"
    local target="0.0.0.0/0"
    [ "${family}" = "6" ] && mark="${IPV6_MARK}" && target="::/0"

    if [ "${action}" = "apply" ]; then
        if [ "${family}" = "6" ]; then
            ip -6 rule add fwmark "${mark}" table "${TABLE_ID}" pref "${TABLE_ID}" >/dev/null 2>&1 || return 1
            ip -6 route replace local "${target}" dev lo table "${TABLE_ID}" >/dev/null 2>&1 || return 1
        else
            ip rule add fwmark "${mark}" table "${TABLE_ID}" pref "${TABLE_ID}" >/dev/null 2>&1 || return 1
            ip route replace local "${target}" dev lo table "${TABLE_ID}" >/dev/null 2>&1 || return 1
        fi
        return 0
    fi

    if [ "${family}" = "6" ]; then
        ip -6 rule del fwmark "${mark}" table "${TABLE_ID}" pref "${TABLE_ID}" >/dev/null 2>&1 || true
        ip -6 route del local "${target}" dev lo table "${TABLE_ID}" >/dev/null 2>&1 || true
    else
        ip rule del fwmark "${mark}" table "${TABLE_ID}" pref "${TABLE_ID}" >/dev/null 2>&1 || true
        ip route del local "${target}" dev lo table "${TABLE_ID}" >/dev/null 2>&1 || true
    fi
    return 0
}

# ==============================================================================
# [ Public API ]
# ==============================================================================

start_proxy() {
    local families="4"
    [ "${PROXY_IPV6}" = "1" ] && families="4 6"

    local f
    for f in ${families}; do
        run -v "Apply IPv${f} Rules" _rules apply "${f}" || return 1
        run -v "Apply IPv${f} Route" _route apply "${f}" || return 1
    done
}

stop_proxy() {
    local families="4"
    [ "${PROXY_IPV6}" = "1" ] && families="4 6"

    local f
    for f in ${families}; do
        run -v "Clean IPv${f} Rules" _rules cleanup "${f}" || true
        run -v "Clean IPv${f} Route" _route cleanup "${f}" || true
    done
}

# ==============================================================================
# [ Entry Point ]
# ==============================================================================

main() {
    local action="${1:-}"

    case "${action}" in
    start)
        start_proxy
        ;;
    stop)
        stop_proxy
        ;;
    *)
        echo "Usage: $0 {start|stop}"
        exit 1
        ;;
    esac
}

main "$@"
